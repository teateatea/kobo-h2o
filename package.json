{
  "name": "kobo-highlights-2-obsidian",
  "version": "1.0.0",
  "description": "Import Kobo highlights into Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npx tsc --noEmit -p tsconfig.json && node esbuild.config.mjs production",
    "deploy": "npm run build && node deploy.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": ["obsidian", "kobo", "highlights", "ereader"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@types/sql.js": "^1.4.4",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.25.0",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "sql.js": "^1.10.2"
  }
}
